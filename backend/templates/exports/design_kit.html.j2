{# design_kit.html.j2 — HTML export template used for PDF generation fallback #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Design Kit</title>
  <style>
    body { font-family: 'Helvetica', 'Arial', sans-serif; color: #1a1a2e; max-width: 800px; margin: 0 auto; padding: 40px 20px; }
    h1 { font-size: 28px; color: #0d0d12; border-bottom: 2px solid #00E5FF; padding-bottom: 8px; }
    h2 { font-size: 18px; color: #333; margin-top: 30px; }
    h3 { font-size: 14px; color: #666; margin-top: 20px; }
    p { font-size: 14px; line-height: 1.6; color: #444; }
    ul { padding-left: 20px; }
    li { font-size: 13px; line-height: 1.8; color: #444; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; }
    .mvp { background: #e0f7fa; color: #00838f; }
    .v2 { background: #f3e5f5; color: #7b1fa2; }
    .effort { background: #f5f5f5; color: #666; }
    .meta { margin-top: 40px; padding-top: 20px; border-top: 1px solid #eee; font-size: 12px; color: #999; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eee; font-size: 13px; }
    th { font-weight: 600; color: #333; background: #f9f9f9; }
  </style>
</head>
<body>
  <h1>Design Kit</h1>

  <h2>Problem Statement</h2>
  <p>{{ problem }}</p>

  <h2>Target Audience</h2>
  <p>{{ audience }}</p>

  <h2>MVP Scope</h2>
  <p>{{ mvp }}</p>

  <h2>Features</h2>
  <h3>MVP</h3>
  <ul>
  {% for block in blocks %}{% if block.is_mvp %}
    <li><strong>{{ block.name }}</strong> <span class="badge effort">{{ block.effort }}</span> — {{ block.description }}</li>
  {% endif %}{% endfor %}
  </ul>

  <h3>Future (V2)</h3>
  <ul>
  {% for block in blocks %}{% if not block.is_mvp %}
    <li><strong>{{ block.name }}</strong> <span class="badge effort">{{ block.effort }}</span> — {{ block.description }}</li>
  {% endif %}{% endfor %}
  </ul>

  <h2>Tech Stack</h2>
  <table>
    <tr><th>Layer</th><th>Tool</th></tr>
    {% for item in pipeline %}
    <tr><td>{{ item.layer | capitalize }}</td><td>{{ item.tool }}</td></tr>
    {% endfor %}
  </table>

  <h2>Constraints</h2>
  <p>{{ tech_constraints }}</p>

  <h2>Success Metric</h2>
  <p>{{ success_metric }}</p>

  <div class="meta">
    <p>Platform: {{ platform }} | Tone: {{ tone }} | Confidence: {{ confidence_score }}%</p>
    <p><em>Generated by Ide/AI</em></p>
  </div>
</body>
</html>
